<Window x:Class="OCREditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OCR Visual Editor Pro" Height="750" Width="1250"
        Background="#181818" WindowStartupLocation="CenterScreen"
        Foreground="#E0E0E0">
    
    <Window.Resources>
        <!-- Modern ScrollViewer style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#2D2D2D"/>
        </Style>

        <!-- Modern Button Style -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="true">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3E3E42"/>
                    <Setter Property="BorderBrush" Value="#555555"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Accent/Primary Button Style -->
        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="BorderBrush" Value="#0098FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0098FF"/>
                    <Setter Property="BorderBrush" Value="#33B4FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Destructive Button Style -->
        <Style x:Key="DestructiveButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#8B0000"/>
            <Setter Property="BorderBrush" Value="#A52A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B22222"/>
                    <Setter Property="BorderBrush" Value="#CD5C5C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Toggle Button Style (for Bold/Italic) -->
        <Style x:Key="ModernToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#007ACC"/>
                    <Setter Property="BorderBrush" Value="#0098FF"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#555555"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Styled ListBox -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#202020"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>

        <!-- Styled ListBoxItem -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#007ACC"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2D2D30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Preset Color Box Style -->
        <Style x:Key="ColorBoxStyle" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ColorBorder" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="#3F3F46" 
                                BorderThickness="1" 
                                CornerRadius="12"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ColorBorder" Property="BorderBrush" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        <!-- Modern ComboBox Style -->
        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                          BorderBrush="{TemplateBinding BorderBrush}" 
                                          Background="{TemplateBinding Background}" 
                                          Foreground="{TemplateBinding Foreground}"
                                          Grid.Column="2" 
                                          Focusable="false"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" 
                                                Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                BorderThickness="1" 
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <Grid.ColumnDefinition Width="*"/>
                                                    <Grid.ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Arrow -->
                                                <Path x:Name="Arrow" 
                                                      Grid.Column="1" 
                                                      Fill="White" 
                                                      HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center" 
                                                      Data="M 0 0 L 4 4 L 8 0 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="true">
                                                <Setter TargetName="Border" Property="Background" Value="#3E3E42"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" 
                                              IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="10,3,30,3"
                                              VerticalAlignment="Center" 
                                              HorizontalAlignment="Left"/>
                            <!-- Popup -->
                            <Popup x:Name="Popup" 
                                   Placement="Bottom" 
                                   IsOpen="{TemplateBinding IsDropDownOpen}" 
                                   AllowsTransparency="True" 
                                   Focusable="False" 
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown" 
                                      SnapsToDevicePixels="True" 
                                      MinWidth="{TemplateBinding ActualWidth}" 
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" 
                                            Background="#2D2D30" 
                                            BorderBrush="#3F3F46" 
                                            BorderThickness="1" 
                                            CornerRadius="4"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Menu/Toolbar -->
        <Border Grid.Row="0" Background="#1E1E1E" Padding="12,8" BorderBrush="#2D2D2D" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">
                <!-- App Title -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="🔍" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="OCR Visual Editor Pro" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Tool Buttons -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Button Content="📂 Open Image" Click="OpenImage_Click" Style="{StaticResource AccentButtonStyle}" Margin="0,0,8,0"/>
                    <Button x:Name="UndoButton" Content="↩️ Undo" Click="Undo_Click" Style="{StaticResource ModernButtonStyle}" Margin="0,0,8,0" IsEnabled="False"/>
                    <Button x:Name="RedoButton" Content="↪️ Redo" Click="Redo_Click" Style="{StaticResource ModernButtonStyle}" Margin="0,0,8,0" IsEnabled="False"/>
                    <Button Content="💾 Save Result" Click="SaveImage_Click" Style="{StaticResource ModernButtonStyle}" Margin="0,0,12,0"/>
                    
                    <Separator Width="1" Height="20" Background="#2D2D2D" Margin="5,0,12,0"/>

                    <ComboBox x:Name="LanguageComboBox" Width="160" Height="26" VerticalAlignment="Center" SelectedIndex="0" Margin="0,0,15,0" Style="{StaticResource ModernComboBoxStyle}">
                        <ComboBox.Resources>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Background" Value="#2D2D30"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Padding" Value="6,4"/>
                            </Style>
                        </ComboBox.Resources>
                        <ComboBoxItem Content="Auto (System)" Tag="auto"/>
                        <ComboBoxItem Content="繁體中文 (zh-Hant)" Tag="zh-Hant"/>
                        <ComboBoxItem Content="English (en)" Tag="en"/>
                        <ComboBoxItem Content="简体中文 (zh-Hans)" Tag="zh-Hans"/>
                        <ComboBoxItem Content="日本語 (ja)" Tag="ja"/>
                        <ComboBoxItem Content="한국어 (ko)" Tag="ko"/>
                        <ComboBoxItem Content="ไทย (th)" Tag="th"/>
                        <ComboBoxItem Content="Русский (ru)" Tag="ru"/>
                        <ComboBoxItem Content="Deutsch (de)" Tag="de"/>
                        <ComboBoxItem Content="Bahasa Indonesia (id)" Tag="id"/>
                        <ComboBoxItem Content="Bahasa Melayu (ms)" Tag="ms"/>
                        <ComboBoxItem Content="Español (es)" Tag="es"/>
                        <ComboBoxItem Content="Português (pt)" Tag="pt"/>
                    </ComboBox>

                    <Separator Width="1" Height="20" Background="#2D2D2D" Margin="5,0,12,0"/>

                    <!-- Zoom Control -->
                    <TextBlock Text="Zoom: " VerticalAlignment="Center" Foreground="#AAA" Margin="0,0,5,0"/>
                    <Button Content=" ➖ " Click="ZoomOut_Click" Style="{StaticResource ModernButtonStyle}" Width="30" Height="26" Margin="0,0,5,0"/>
                    <Slider x:Name="ZoomSlider" Minimum="0.2" Maximum="3" Value="1" Width="100" ValueChanged="ZoomSlider_ValueChanged" VerticalAlignment="Center"/>
                    <Button Content=" ➕ " Click="ZoomIn_Click" Style="{StaticResource ModernButtonStyle}" Width="30" Height="26" Margin="5,0,8,0"/>
                    <Button Content="100%" Click="ZoomReset_Click" Style="{StaticResource ModernButtonStyle}" Height="26"/>
                </StackPanel>

                <TextBlock x:Name="EngineIndicator" Text="Engine: System OCR" DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="#888" FontSize="12"/>
            </DockPanel>
        </Border>

        <!-- Main Workspace -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>  <!-- Left Sidebar: Layer List & Status -->
                <ColumnDefinition Width="*"/>    <!-- Center Canvas -->
                <ColumnDefinition Width="340"/>  <!-- Right Inspector: Formatting Panel -->
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDEBAR: Layers List -->
            <Border Grid.Column="0" Background="#202020" BorderBrush="#2D2D2D" BorderThickness="0,0,1,0" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Document Status" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                    <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="4" Padding="8" Margin="0,0,0,15" BorderBrush="#2D2D2D" BorderThickness="1">
                        <StackPanel>
                            <TextBlock x:Name="StatusLabel" Text="No Image Loaded" TextWrapping="Wrap" Foreground="#AAA" FontSize="12"/>
                            <ProgressBar x:Name="OcrProgressBar" Height="4" Margin="0,8,0,0" Background="#2D2D30" BorderThickness="0" IsIndeterminate="False" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <DockPanel Grid.Row="2">
                        <TextBlock DockPanel.Dock="Top" Text="Interactive Text Layers" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                        <ListBox x:Name="LayerListBox" SelectionChanged="LayerListBox_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4">
                                        <TextBlock Text="📝" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding OriginalText}" TextTrimming="CharacterEllipsis" Width="180" Foreground="#E0E0E0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Grid>
            </Border>

            <!-- CENTER CANVAS AREA -->
            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#0F0F0F">
                <Grid x:Name="CanvasGrid" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                    <Grid.LayoutTransform>
                        <ScaleTransform x:Name="CanvasScale" ScaleX="1" ScaleY="1"/>
                    </Grid.LayoutTransform>
                    <Image x:Name="SourceImage" Stretch="None" SizeChanged="SourceImage_SizeChanged"/>
                    <Canvas x:Name="OverlayCanvas" Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                </Grid>
            </ScrollViewer>

            <!-- RIGHT INSPECTOR: Formatting & Action Panel -->
            <Border Grid.Column="2" Background="#202020" BorderBrush="#2D2D2D" BorderThickness="1,0,0,0" Padding="15">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Text Formatting Panel" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                        <Separator Background="#2D2D2D" Margin="0,0,0,10"/>

                        <!-- Text Editor -->
                        <TextBlock Text="Edit Content" FontWeight="SemiBold" Foreground="#CCC" Margin="0,0,0,5"/>
                        <TextBox x:Name="OcrTextBox" AcceptsReturn="True" TextWrapping="Wrap" Height="100" 
                                 Background="#181818" Foreground="White" BorderBrush="#2D2D2D" 
                                 Padding="8" FontSize="13" TextChanged="OcrTextBox_TextChanged"/>

                        <!-- Formatting Controls (Bold, Italic, FontSize) -->
                        <TextBlock Text="Paragraph Format" FontWeight="SemiBold" Foreground="#CCC" Margin="0,15,0,5"/>
                        <Border Background="#1E1E1E" CornerRadius="4" Padding="10" BorderBrush="#2D2D2D" BorderThickness="1">
                            <StackPanel>
                                <!-- Font Size -->
                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock Text="Size: " VerticalAlignment="Center" Foreground="#AAA"/>
                                    <TextBlock x:Name="FontSizeValueText" Text="16px" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="White" Width="40" TextAlignment="Right"/>
                                    <Slider x:Name="FontSizeSlider" Minimum="8" Maximum="72" Value="16" 
                                            ValueChanged="FontSizeSlider_ValueChanged" VerticalAlignment="Center"/>
                                </DockPanel>

                                <!-- Styles (Bold, Italic) -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
                                    <ToggleButton x:Name="BoldToggleButton" Content=" Bold " Width="70" Height="26" 
                                                  Style="{StaticResource ModernToggleButtonStyle}" Click="BoldToggle_Click" Margin="0,0,8,0"/>
                                    <ToggleButton x:Name="ItalicToggleButton" Content=" Italic " Width="70" Height="26" 
                                                  Style="{StaticResource ModernToggleButtonStyle}" Click="ItalicToggle_Click"/>
                                </StackPanel>

                                <!-- Text Color -->
                                <TextBlock Text="Color Presets: " Foreground="#AAA" Margin="0,0,0,6"/>
                                <WrapPanel HorizontalAlignment="Left">
                                    <Button Background="Black" Style="{StaticResource ColorBoxStyle}" Click="PresetColor_Click"/>
                                    <Button Background="White" Style="{StaticResource ColorBoxStyle}" Click="PresetColor_Click"/>
                                    <Button Background="Red" Style="{StaticResource ColorBoxStyle}" Click="PresetColor_Click"/>
                                    <Button Background="Green" Style="{StaticResource ColorBoxStyle}" Click="PresetColor_Click"/>
                                    <Button Background="Blue" Style="{StaticResource ColorBoxStyle}" Click="PresetColor_Click"/>
                                    <Button Background="Yellow" Style="{StaticResource ColorBoxStyle}" Click="PresetColor_Click"/>
                                    <Button Background="Orange" Style="{StaticResource ColorBoxStyle}" Click="PresetColor_Click"/>
                                    <Button Background="Purple" Style="{StaticResource ColorBoxStyle}" Click="PresetColor_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- Actions (Inpainting & Translation) -->
                        <TextBlock Text="Operations" FontWeight="SemiBold" Foreground="#CCC" Margin="0,15,0,5"/>
                        <StackPanel>
                            <Button Content="🌐 Translate to Traditional Chinese" Click="Translate_Click" 
                                    Style="{StaticResource ModernButtonStyle}" Margin="0,0,0,8"/>
                            <Button Content="🗑️ Remove Text Region" Click="RemoveText_Click" 
                                    Style="{StaticResource DestructiveButtonStyle}"/>
                        </StackPanel>

                        <!-- Help Notice -->
                        <TextBlock Text="Tip: If AI missed a word, click-and-drag directly on the image to draw a manual text box!" 
                                   Foreground="#888" TextWrapping="Wrap" FontSize="11" Margin="0,20,0,0" LineHeight="15"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#007ACC" Padding="10,4" BorderBrush="#005B9A" BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock Text="OCR Visual Editor Professional — Powered by Windows AI Platform" Foreground="White" FontSize="11" HorizontalAlignment="Left"/>
                <TextBlock x:Name="DpiIndicator" Text="Zoom: 100%" Foreground="#D0D0D0" FontSize="11" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>
