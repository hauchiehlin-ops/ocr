<Window x:Class="OCREditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OCR Visual Editor" Height="650" Width="950"
        Background="#1E1E1E" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Menu/Toolbar -->
        <Border Grid.Row="0" Background="#2D2D30" Padding="10" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="Open Image" Click="OpenImage_Click" Padding="12,6" Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"/>
                <Button Content="Remove Text" Click="RemoveText_Click" Padding="12,6" Background="#4E4E50" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"/>
                <Button Content="Save Result" Click="SaveImage_Click" Padding="12,6" Background="#4E4E50" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"/>
            </StackPanel>
        </Border>

        <!-- Main Workspace -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Image Canvas -->
            <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#121212">
                <Grid x:Name="CanvasGrid" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                    <Image x:Name="SourceImage" Stretch="None"/>
                    <Canvas x:Name="OverlayCanvas" Background="Transparent"/>
                </Grid>
            </ScrollViewer>

            <!-- Properties Panel -->
            <Border Grid.Column="1" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1,0,0,0" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Properties Panel" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                    <Separator Grid.Row="1" Background="#3F3F46" Margin="0,0,0,15"/>
                    <TextBlock Grid.Row="2" Text="OCR Text Results" FontWeight="SemiBold" Foreground="#CCC" Margin="0,0,0,8"/>
                    
                    <TextBox Grid.Row="3" x:Name="OcrTextBox" AcceptsReturn="True" TextWrapping="Wrap" Background="#1E1E1E" Foreground="White" BorderBrush="#3F3F46" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Padding="5"/>
                    
                    <TextBlock Grid.Row="4" x:Name="StatusLabel" Text="Ready" Foreground="#888" Margin="0,10,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#007ACC" Padding="5,3">
            <TextBlock Text="OCR Visual Editor v1.0.0 (Windows Core Engine)" Foreground="White" FontSize="11" HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
