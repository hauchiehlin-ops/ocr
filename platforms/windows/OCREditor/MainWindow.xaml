<ui:FluentWindow x:Class="OCREditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="OCR Visual Editor Pro" Height="750" Width="1250"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round"
        Icon="app_icon.ico">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TitleBar -->
        <ui:TitleBar Grid.Row="0" Title="OCR Visual Editor Pro" Icon="app_icon.ico">
            <ui:TitleBar.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Menu Grid.Column="0" Background="Transparent" VerticalAlignment="Center" Margin="10,0,0,0">
                        <MenuItem Header="{DynamicResource FileMenu}">
                            <MenuItem Header="{DynamicResource LoadImage}" Click="OpenImage_Click"/>
                            <MenuItem Header="Close Image" Click="CloseImage_Click"/>
                            <MenuItem Header="{DynamicResource SaveImage}" Click="SaveImage_Click"/>
                            <Separator/>
                            <MenuItem Header="Export to CSV" Click="ExportCSV_Click"/>
                            <MenuItem Header="Export to Searchable PDF" Click="ExportPDF_Click"/>
                        </MenuItem>
                        <MenuItem Header="{DynamicResource EditMenu}">
                            <MenuItem x:Name="MenuInsertText" Header="{DynamicResource InsertText}" IsCheckable="True"/>
                            <Separator/>
                            <MenuItem Header="{DynamicResource ApplyDefaultFont}" Click="ApplyDefaultFontToAll_Click"/>
                            <Separator/>
                            <MenuItem x:Name="MenuUndo" Header="{DynamicResource Undo}" Click="Undo_Click" IsEnabled="False"/>
                            <MenuItem x:Name="MenuRedo" Header="{DynamicResource Redo}" Click="Redo_Click" IsEnabled="False"/>
                        </MenuItem>
                        <MenuItem Header="{DynamicResource ViewMenu}">
                            <MenuItem x:Name="MenuToggleLeft" Header="{DynamicResource ShowLeftPanel}" IsCheckable="True" IsChecked="True" Click="ToggleLeftPanel_Click"/>
                            <MenuItem x:Name="MenuToggleRight" Header="{DynamicResource ShowRightPanel}" IsCheckable="True" IsChecked="True" Click="ToggleRightPanel_Click"/>
                        </MenuItem>
                        
                        <MenuItem Header="{DynamicResource SettingsMenu}">
                            <MenuItem Header="UI Language">
                                <ComboBox x:Name="UiLanguageComboBox" Width="160" Height="26" SelectedIndex="0" SelectionChanged="UiLanguageComboBox_SelectionChanged">
                                    <ComboBoxItem Content="English" Tag="English"/>
                                    <ComboBoxItem Content="繁體中文" Tag="繁體中文"/>
                                    <ComboBoxItem Content="简体中文" Tag="简体中文"/>
                                    <ComboBoxItem Content="日本語" Tag="日本語"/>
                                    <ComboBoxItem Content="한국어" Tag="한국어"/>
                                    <ComboBoxItem Content="ไทย" Tag="ไทย"/>
                                    <ComboBoxItem Content="Español" Tag="Español"/>
                                    <ComboBoxItem Content="Português" Tag="Português"/>
                                    <ComboBoxItem Content="Bahasa Melayu" Tag="Bahasa Melayu"/>
                                    <ComboBoxItem Content="Русский" Tag="Русский"/>
                                    <ComboBoxItem Content="Deutsch" Tag="Deutsch"/>
                                </ComboBox>
                            </MenuItem>
                            <MenuItem Header="{DynamicResource ForceComputerFont}" x:Name="MenuForceComputerFont" IsCheckable="True"/>
                            <MenuItem Header="{DynamicResource PrimaryDefaultFont}">
                                <ComboBox x:Name="PrimaryFontComboBox" Width="160" Height="26" SelectedIndex="0"/>
                            </MenuItem>
                            <MenuItem Header="{DynamicResource SecondaryDefaultFont}">
                                <ComboBox x:Name="SecondaryFontComboBox" Width="160" Height="26" SelectedIndex="0"/>
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="OCR Language">
                                <ComboBox x:Name="LanguageComboBox" Width="160" Height="26" SelectedIndex="0" SelectionChanged="LanguageComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Auto (System)" Tag="auto"/>
                                    <ComboBoxItem Content="繁體中文 (zh-Hant)" Tag="zh-Hant"/>
                                    <ComboBoxItem Content="English (en)" Tag="en"/>
                                    <ComboBoxItem Content="简体中文 (zh-Hans)" Tag="zh-Hans"/>
                                    <ComboBoxItem Content="日本語 (ja)" Tag="ja"/>
                                    <ComboBoxItem Content="한국어 (ko)" Tag="ko"/>
                                    <ComboBoxItem Content="ไทย (th)" Tag="th"/>
                                    <ComboBoxItem Content="Русский (ru)" Tag="ru"/>
                                    <ComboBoxItem Content="Deutsch (de)" Tag="de"/>
                                    <ComboBoxItem Content="Bahasa Indonesia (id)" Tag="id"/>
                                    <ComboBoxItem Content="Bahasa Melayu (ms)" Tag="ms"/>
                                    <ComboBoxItem Content="Español (es)" Tag="es"/>
                                    <ComboBoxItem Content="Português (pt)" Tag="pt"/>
                                </ComboBox>
                            </MenuItem>
                        </MenuItem>
                    </Menu>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock x:Name="EngineIndicator" Text="Engine: System OCR" VerticalAlignment="Center" Margin="0,0,15,0" Opacity="0.7"/>
                        <TextBlock Text="{DynamicResource Zoom}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ui:Button Icon="{ui:SymbolIcon ZoomOut24}" Click="ZoomOut_Click" Appearance="Transparent" Margin="0,0,2,0"/>
                        <TextBlock Text="{Binding ElementName=ZoomSlider, Path=Value, StringFormat={}{0:P0}}" Width="50" VerticalAlignment="Center" TextAlignment="Center"/>
                        <ui:Button Icon="{ui:SymbolIcon ZoomIn24}" Click="ZoomIn_Click" Appearance="Transparent" Margin="2,0,8,0"/>
                        <Slider x:Name="ZoomSlider" Width="100" Minimum="0.1" Maximum="5.0" Value="1.0" ValueChanged="ZoomSlider_ValueChanged" VerticalAlignment="Center" Margin="0,0,8,0" TickFrequency="0.05" IsSnapToTickEnabled="False"/>
                        <ui:Button Content="100%" Click="ZoomReset_Click" Appearance="Secondary" Padding="8,4" Margin="0"/>
                    </StackPanel>
                </Grid>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- Main Workspace -->
        <Grid Grid.Row="1" Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>  <!-- Left Sidebar -->
                <ColumnDefinition Width="*"/>    <!-- Center Canvas -->
                <ColumnDefinition Width="Auto"/>  <!-- Right Inspector -->
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDEBAR -->
            <ui:Card x:Name="LeftSidebar" Grid.Column="0" Width="260" Margin="0,0,10,0" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{DynamicResource DocumentStatus}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    
                    <Border Grid.Row="1" Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="8" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock x:Name="StatusLabel" Text="No Image Loaded" TextWrapping="Wrap" Opacity="0.7" FontSize="12"/>
                            <ProgressBar x:Name="OcrProgressBar" Height="4" Margin="0,8,0,0" IsIndeterminate="False" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <DockPanel Grid.Row="2">
                        <TextBlock DockPanel.Dock="Top" Text="{DynamicResource InteractiveLayers}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ListBox x:Name="LayerListBox" SelectionChanged="LayerListBox_SelectionChanged" BorderThickness="0" Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4">
                                        <ui:SymbolIcon Symbol="Layer24" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding OriginalText}" TextTrimming="CharacterEllipsis" Width="180" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Grid>
            </ui:Card>

            <!-- CENTER CANVAS AREA -->
            <ui:Card Grid.Column="1" Padding="0" Margin="0">
                <ScrollViewer x:Name="MainScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Border Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid x:Name="CanvasGrid">
                            <Grid.LayoutTransform>
                                <ScaleTransform x:Name="CanvasScale" ScaleX="1" ScaleY="1"/>
                            </Grid.LayoutTransform>
                            <Image x:Name="SourceImage" Stretch="None" SizeChanged="SourceImage_SizeChanged"/>
                            <Canvas x:Name="OverlayCanvas" Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Top" MouseLeftButtonDown="OverlayCanvas_MouseLeftButtonDown"/>
                        </Grid>
                    </Border>
                </ScrollViewer>
            </ui:Card>

            <!-- RIGHT INSPECTOR -->
            <ui:Card x:Name="RightSidebar" Grid.Column="2" Width="340" Margin="10,0,0,0" Padding="15">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="{DynamicResource TextFormattingPanel}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <!-- Text Editor -->
                        <TextBlock Text="{DynamicResource EditContent}" FontWeight="SemiBold" Opacity="0.7" Margin="0,0,0,5"/>
                        <ui:TextBox x:Name="OcrTextBox" AcceptsReturn="True" TextWrapping="Wrap" Height="100" 
                                 Padding="8" FontSize="13" TextChanged="OcrTextBox_TextChanged" Margin="0,0,0,15"/>

                        <!-- Formatting Controls -->
                        <TextBlock Text="{DynamicResource ParagraphFormat}" FontWeight="SemiBold" Opacity="0.7" Margin="0,0,0,5"/>
                        <Border Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="10">
                            <StackPanel>
                                <!-- Font Size -->
                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock Text="{DynamicResource Size}" VerticalAlignment="Center" Opacity="0.7"/>
                                    <TextBlock x:Name="FontSizeValueText" Text="16px" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="10,0,0,0" Width="45" TextAlignment="Right"/>
                                    <Slider x:Name="FontSizeSlider" Minimum="8" Maximum="400" Value="16" ValueChanged="FontSizeSlider_ValueChanged" VerticalAlignment="Center"/>
                                </DockPanel>

                                <!-- Font Family -->
                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock Text="{DynamicResource Font}" VerticalAlignment="Center" Opacity="0.7" Width="40"/>
                                    <ComboBox x:Name="FontFamilyComboBox" SelectionChanged="FontFamilyComboBox_SelectionChanged" VerticalAlignment="Center"/>
                                </DockPanel>

                                <!-- Styles -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
                                    <ToggleButton x:Name="BoldToggleButton" Content="{DynamicResource Bold}" Width="70" Height="28" Click="BoldToggle_Click" Margin="0,0,8,0"/>
                                    <ToggleButton x:Name="ItalicToggleButton" Content="{DynamicResource Italic}" Width="70" Height="28" Click="ItalicToggle_Click"/>
                                </StackPanel>

                                <!-- Text Color -->
                                <TextBlock Text="{DynamicResource ColorPresets}" Opacity="0.7" Margin="0,0,0,6"/>
                                <WrapPanel Margin="0,0,0,15">
                                    <Button Background="#000000" Click="ColorPreset_Click" Width="24" Height="24" Margin="4" Padding="0"/>
                                    <Button Background="#E0E0E0" Click="ColorPreset_Click" Width="24" Height="24" Margin="4" Padding="0"/>
                                    <Button Background="#FF0000" Click="ColorPreset_Click" Width="24" Height="24" Margin="4" Padding="0"/>
                                    <Button Background="#0000FF" Click="ColorPreset_Click" Width="24" Height="24" Margin="4" Padding="0"/>
                                    <Button Background="#008000" Click="ColorPreset_Click" Width="24" Height="24" Margin="4" Padding="0"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="AI Operations (Local LLM)" FontWeight="SemiBold" Opacity="0.7" Margin="0,20,0,5"/>
                        <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <ui:Button Content="Fix Text" Click="FixTextWithLLM_Click" Appearance="Secondary" Width="145" Margin="0,0,10,0"/>
                                <ui:Button Content="Extract Entities" Click="ExtractEntitiesWithLLM_Click" Appearance="Secondary" Width="145"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <ui:Button Content="Translate to ZH" Click="TranslateWithLLM_Click" Appearance="Secondary" Width="145" Margin="0,0,10,0"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="Operations" FontWeight="SemiBold" Opacity="0.7" Margin="0,20,0,5"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <ToggleButton x:Name="RegionOcrToggleButton" Content="Regional Re-OCR" Width="145" Margin="0,0,10,0"
                                          Checked="RegionOcrToggle_Checked" Unchecked="RegionOcrToggle_Unchecked"/>
                            <ui:Button Content="{DynamicResource RemoveText}" Click="RemoveText_Click" Appearance="Secondary" Width="145"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </ui:Card>
        </Grid>

        <!-- Bottom Status Bar -->
        <Border Grid.Row="2" Background="{DynamicResource ControlFillColorDefaultBrush}" Padding="10,4">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="Version 1.0 (Alpha)" Opacity="0.6" FontSize="11" Margin="0,0,15,0"/>
                <TextBlock x:Name="DpiIndicator" Text="Image DPI: --" Opacity="0.6" FontSize="11"/>
            </StackPanel>
        </Border>

    </Grid>
</ui:FluentWindow>
